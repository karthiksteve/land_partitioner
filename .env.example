# GeoKurra - Digital Land Information Portal
# Environment Configuration

# Application
PROJECT_NAME=GeoKurra
VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql+asyncpg://geokurra:geokurra@localhost:5432/geokurra
DATABASE_URL_SYNC=postgresql://geokurra:geokurra@localhost:5432/geokurra

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# API
API_V1_PREFIX=/api/v1

# BhuNaksha Integration
BHUNAKSHA_BASE_URL=https://bhunaksha.bihar.gov.in
BHUNAKSHA_TIMEOUT=30
BHUNAKSHA_RETRY_COUNT=3

# Uploads
UPLOAD_DIR=uploads/documents
MAX_UPLOAD_SIZE=10485760

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MAP_CENTER_LAT=25.6
NEXT_PUBLIC_MAP_CENTER_LNG=85.1
NEXT_PUBLIC_DEFAULT_ZOOM=12
