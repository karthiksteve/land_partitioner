# GeoKurra Environment Configuration
# Copy this to .env and fill in your values

# Application
PROJECT_NAME=GeoKurra
VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://geokurra:geokurra@localhost:5432/geokurra
DATABASE_URL_SYNC=postgresql://geokurra:geokurra@localhost:5432/geokurra

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# API
API_V1_PREFIX=/api/v1

# BhuNaksha Integration
BHUNakSHA_BASE_URL=https://bhunaksha.bihar.gov.in
BHUNakSHA_TIMEOUT=30
BHUNakSHA_RETRY_COUNT=3

# AI Model
AI_MODEL_PATH=./models
AI_MODEL_NAME=qwen-3-8b

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
